{% set _menu_active = 'etablissement' %}
{% extends 'base.html.twig' %}

{% block title %}Création passage {{ passage.etablissement.nom }}{% endblock title %}

{% block body %}
    <div class="row">
        <div class="col-xs-12 form-horizontal">

            <ol class="breadcrumb">
                <li><a href="{{ path('passage') }}">Passage</a></li>
                <li><a href="{{ path('passage_etablissement',{ 'id' : passage.etablissement.id }) }}">{{ passage.etablissement.nom }}&nbsp;<small>{{passage.etablissement.adresse.intitule }}</small></a></li>
                <li><a href="">Création d'un passage</a></li>
            </ol>

            {{ form_start(form) }}

            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title">Création d'un passage pour le contrat n° {{ passage.contrat.numeroArchive }}</h3>
                </div>
                <div class="panel-body">
                    <div class="form-group">
    	                {{ form_errors(form.typePassage) }}
                        {{ form_label(form.typePassage, "Type de passage", {'label_attr': {'class': 'col-xs-2 contral-label'}}) }}
                        <div class="col-xs-4">
    	                    {{ form_widget(form.typePassage, {'attr': {'autofocus': 'autofocus'}}) }}
                        </div>
    	            </div>

    	            <div class="form-group">
    	                {{ form_errors(form.datePrevision) }}
                        {{ form_label(form.datePrevision, "Date de prévision", {'label_attr': {'class': 'col-xs-2 contral-label'}}) }}
                        <div class="col-xs-4">
        	                <div class="input-group">
        	                    {{ form_widget(form.datePrevision) }}
        	                    <div class="input-group-addon"><span class="glyphicon glyphicon-calendar"></span></div>
        	                </div>
                        </div>
    	            </div>
    	            <div class="form-group prix-unitaire-hc">
                     <div>
    	                {{ form_errors(form.prixUnitaireHorsContrat) }}
                        {{ form_label(form.prixUnitaireHorsContrat, "Prix Unitaire", {'label_attr': {'class': 'col-xs-2'}}) }}
                        <div class="col-xs-4">
        	                <div class="input-group">
                             {{ form_widget(form.prixUnitaireHorsContrat, {'attr': {'class': 'text-right prix-unitaire form-control'}}) }}
        	                    <div class="input-group-addon">€ HT</div>
        	                </div>
                        </div>
                     </div>
                        <div>
                            {{ form_errors(form.tauxTaxeHorsContrat) }}
                            {{ form_label(form.tauxTaxeHorsContrat, "Taux de TVA", {'label_attr': {'class': 'col-xs-2'}}) }}
                            <div class="col-xs-1">
                                {{ form_widget(form.tauxTaxeHorsContrat, {'attr': {'class': 'text-right prix-unitaire form-control'}}) }}
                            </div>
                        </div>
                        <div class="clearfix">
                          <p class="">
                            <strong>Total :</strong> <span id="totalTTCHorsContrat"></span> € TTC
                          </p>
                        </div>
    	            </div>

                    <div class="form-group">
    	                {{ form_errors(form.techniciens) }}
                        {{ form_label(form.techniciens, "Techniciens", {'label_attr': {'class': 'col-xs-2 contral-label'}}) }}
                        <div class="col-xs-10">
    	                    {{ form_widget(form.techniciens) }}
                        </div>
    	            </div>

                    <div class="form-group">
    	                {{ form_errors(form.prestations) }}
                        {{ form_label(form.prestations, "Prestations", {'label_attr': {'class': 'col-xs-2 contral-label'}}) }}
                        <div class="col-xs-10">
    	                    {{ form_widget(form.prestations) }}
                        </div>
    	            </div>
                </div>
            </div>
            <div class="row">
                <div class="col-xs-12 text-right">
                    <button type="submit" name="action" value="creer_planifier" class="btn btn-default">Créer et planifer le passage</button>
                    <button type="submit" name="action" value="creer" class="btn btn-primary">Créer</button>
                </div>
            </div>
        	{{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script type="text/javascript">
        // Afficher le champs prix unitaire dynamiquement

        const delay = ms => new Promise(res => setTimeout(res, ms));

        const getSelectPassageHorsContrat = async () => {
            await delay(1);

            const typePassageSpan = document.getElementById("select2-passage_typePassage-container");

           showHidePrixUnitaireHC(typePassageSpan.title);

            new MutationObserver(function(mutations) {
                const typePassageTitle = typePassageSpan.title;
                showHidePrixUnitaireHC(typePassageSpan.title);
            }).observe(
                typePassageSpan,
                { subtree: true, characterData: true, childList: true }
            );
        }

        getSelectPassageHorsContrat();

        function showHidePrixUnitaireHC(typePassageSpan) {
            const prixUnitaireHCGroup = document.getElementsByClassName("prix-unitaire-hc");
            if (typePassageSpan != "Hors contrat - Facturant") {
                prixUnitaireHCGroup[0].style.display = "none";
            } else {
                prixUnitaireHCGroup[0].style.display = "block";

                showTotalTTCPassageHorsContrat();
            }

            function showTotalTTCPassageHorsContrat() {
                let totalTTC = 0;
                let prixHT = document.getElementById("passage_prixUnitaireHorsContrat");

                let tauxTVA = document.getElementById("passage_tauxTaxeHorsContrat");

                updateTotalTTCPassageHorsContrat(prixHT, tauxTVA);

                let infosPrixArray = document.querySelectorAll("#passage_prixUnitaireHorsContrat, #passage_tauxTaxeHorsContrat");

                infosPrixArray.forEach(function(info){
                    info.addEventListener('change', function() {
                    let prixHT = document.getElementById("passage_prixUnitaireHorsContrat");

                    let tauxTVA = document.getElementById("passage_tauxTaxeHorsContrat");
                    updateTotalTTCPassageHorsContrat(prixHT, tauxTVA);
                    });
                });
            }

            showTotalTTCPassageHorsContrat();

            function updateTotalTTCPassageHorsContrat(prixHT, tauxTVA) {
                document.getElementById("totalTTCHorsContrat").innerHTML = (Number(prixHT.value.replace(",", ".")) +(Number(prixHT.value.replace(",", ".")) * Number(tauxTVA.value.replace(",", ".")))).toFixed(2);
            }
        }

    </script>
{% endblock %}
